{
  "info": {
    "name": "Copilot RSSI - Backend API",
    "description": "Collection Postman pour tester le backend Spring Boot",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "1. Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "2. Login RSSI",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var json = pm.response.json();",
              "    pm.collectionVariables.set('token', json.data.token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"rssi\",\n  \"password\": \"rssi123\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      }
    },
    {
      "name": "3. Login Admin",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      }
    },
    {
      "name": "4. Profil connecté (me)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/auth/me"
      }
    },
    {
      "name": "5. Scanner dossier (Inventaire)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"directoryPath\": \"D:\\\\Stage_IA\\\\sample-documents\"\n}"
        },
        "url": "{{baseUrl}}/inventory/scan"
      }
    },
    {
      "name": "6. Lister documents",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/inventory/documents"
      }
    },
    {
      "name": "7. Analyser document (id=1)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/inventory/documents/1/analyze"
      }
    },
    {
      "name": "8. Lister actifs",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/assets"
      }
    },
    {
      "name": "9. Créer actif",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Serveur RH\",\n  \"assetType\": \"INFORMATIONNEL\",\n  \"description\": \"Serveur dossiers RH\",\n  \"owner\": \"RSSI\",\n  \"criticality\": \"ELEVEE\"\n}"
        },
        "url": "{{baseUrl}}/assets"
      }
    },
    {
      "name": "10. Lister risques",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/ai/risks"
      }
    },
    {
      "name": "11. Chat Copilote IA",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question\": \"Quels documents contiennent un CIN ?\"\n}"
        },
        "url": "{{baseUrl}}/ai/chat"
      }
    }
  ]
}
